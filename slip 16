## Q1) Recipe Book using Node.js

// file: recipebook.js

// Recipe Book using Node.js

const recipes = [
    {
        id: 1,
        name: "Pav Bhaji",
        ingredients: ["Potato", "Tomato", "Butter", "Pav"],
        preparationTime: "30 Minutes"
    },
    {
        id: 2,
        name: "Veg Biryani",
        ingredients: ["Rice", "Vegetables", "Spices"],
        preparationTime: "45 Minutes"
    },
    {
        id: 3,
        name: "Masala Dosa",
        ingredients: ["Rice Batter", "Potato", "Masala"],
        preparationTime: "25 Minutes"
    }
];

// Display all recipes
console.log("===== RECIPE BOOK =====\n");

recipes.forEach(recipe => {
    console.log("Recipe ID:", recipe.id);
    console.log("Recipe Name:", recipe.name);
    console.log("Ingredients:", recipe.ingredients.join(", "));
    console.log("Preparation Time:", recipe.preparationTime);
    console.log("----------------------------");
});

## Q2) Event Driven Application

// file: main.js

// Import events module
const EventEmitter = require('events');

// Create object of EventEmitter
const eventEmitter = new EventEmitter();

// Callback function
const myEventHandler = () => {
    console.log("Event detected and callback function executed!");
};

// Listen for event named 'message'
eventEmitter.on('message', myEventHandler);

// Main loop simulation
console.log("Application is running and waiting for events...");

// Trigger the event after 3 seconds
setTimeout(() => {
    console.log("Event Occurred!");
    eventEmitter.emit('message');
}, 3000);
