## Q2) AngularJS Username Validation

<!DOCTYPE html>
<html ng-app="myApp">

<head>
    <title>AngularJS Validation</title>

    <!-- AngularJS Library -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <script>
        // Create AngularJS App
        var app = angular.module("myApp", []);

        // Create Controller
        app.controller("myController", function ($scope) {

            $scope.validate = function () {

                // Username blank validation
                if (!$scope.username || $scope.username.trim() == "") {
                    alert("Enter username");
                    return;
                }

                // Username length validation
                if ($scope.username.length < 3) {
                    alert("Username is too short");
                    return;
                }

                // Password validation
                if (!$scope.password || $scope.password.length < 8) {
                    alert("Password should be minimum 8 characters");
                    return;
                }

                // Success message
                alert("Valid username");
            };
        });
    </script>
</head>

<body ng-controller="myController">

    <h2>User Validation Form</h2>

    <form ng-submit="validate()">

        Username:
        <input type="text" ng-model="username">
        <br><br>

        Password:
        <input type="password" ng-model="password">
        <br><br>

        <input type="submit" value="Submit">

    </form>

</body>
</html>
